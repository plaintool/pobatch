        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="common\powrap.pas"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="units\formattool.pas"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="units\stringgridhelper.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="StringGridHelper"/>
      </Unit>
      <Unit>
        <Filename Value="units\colorhelper.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="ColorHelper"/>
      </Unit>
      <Unit>
        <Filename Value="common\oneshottimer.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="OneShotTimer"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <PathDelim Value="\"/>
    <Target>
      <Filename Value="pobatch"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <OtherUnitFiles Value="common;forms;units"/>
      <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Parsing>
      <SyntaxOptions>
        <IncludeAssertionCode Value="True"/>
      </SyntaxOptions>
